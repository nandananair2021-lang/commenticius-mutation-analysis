    "def classify_mutation(wt, mut):\n",
    "    if len(mut)>len(wt):\n",
    "        return \"Insertion\"\n",
    "    elif len(mut)<len(wt):\n",
    "        return \"Deletion\"\n",
    "    elif wt!=mut:\n",
    "        return \"Substitution\"\n",
    "    else:\n",
    "        return \"None\"\n",
    "\n",
    "master_df[\"Mutation_Type\"] = master_df.apply(\n",
    "lambda row: classify_mutation(\n",
    "row[\"WildType.Sequence\"],\n",
    "row[\"Mutant.Sequence\"]\n",
    "),\n",
    "axis=1\n",
    ")"
   ]
