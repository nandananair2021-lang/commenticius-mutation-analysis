    "def mutation_region(wt, mut):\n",
    "\n",
    "    for i,(a,b) in enumerate(zip(wt, mut)):\n",
    "        if a != b:\n",
    "            if i < 1000:\n",
    "                return \"Promoter\"\n",
    "            else:\n",
    "                return \"Coding\"\n",
    "\n",
    "    if len(wt) != len(mut):\n",
    "        if min(len(wt), len(mut)) < 1000:\n",
    "            return \"Promoter\"\n",
    "        else:\n",
    "            return \"Coding\"\n",
    "\n",
    "    return \"Unknown\"\n",
    "\n",
    "master_df[\"Mutation_Region\"] = master_df.apply(\n",
    "lambda row: mutation_region(\n",
    "row[\"WildType.Sequence\"],\n",
    "row[\"Mutant.Sequence\"]\n",
    "),\n",
    "axis=1\n",
    ")"
   ]
