    "import pandas as pd\n",
    "import glob\n",
    "import os\n",
    "\n",
    "# Find all assignment txt files\n",
    "files = glob.glob(\"*data_file*.txt\")\n",
    "\n",
    "print(\"Files found:\")\n",
    "print(files)\n",
    "\n",
    "# Store dataframes\n",
    "all_data = []\n",
    "\n",
    "for file in files:\n",
    "    \n",
    "    # Read as tab-delimited text\n",
    "    df = pd.read_csv(file, sep=\"\\t\")\n",
    "    \n",
    "    # Add gene name from filename\n",
    "    gene = file.split(\"_data_file\")[0]\n",
    "    df[\"Gene\"] = gene\n",
    "    \n",
    "    all_data.append(df)\n",
    "\n",
    "# Combine everything\n",
    "master_df = pd.concat(all_data, ignore_index=True)\n",
    "\n",
    "# Preview\n",
    "display(master_df.head())\n",
    "\n",
    "# Checks\n",
    "print(\"Rows:\", master_df.shape[0])\n",
    "print(\"Columns:\", master_df.shape[1])\n",
    "print(\"Genes loaded:\", master_df[\"Gene\"].nunique())"
   ]
  },
